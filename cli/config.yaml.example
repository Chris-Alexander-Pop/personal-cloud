woodpecker:
  url: http://100.x.x.x:8000
  token: YOUR_WOODPECKER_PERSONAL_TOKEN
vm:
  ssh: deploy
personal_cloud:
  owner: your-github-username
  repo: personal-cloud
  local_path: ~/personal-cloud
github:
  owner: your-github-username
defaults:
  tailnet_base: example.ts.net
  registry: ghcr.io
ghcr:
  token: YOUR_GITHUB_PAT_WITH_PACKAGES
