# Generated by personal-cloud ship — do not edit by hand
name: ${APP_NAME}

services:
  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: app
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: app
    volumes:
      - ${APP_NAME}_pg:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U app"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - internal

  server:
    image: ${IMAGE}:${IMAGE_TAG}
    container_name: ${SERVICE_CONTAINER}
    restart: unless-stopped
    init: true
    stop_grace_period: 30s
    env_file:
      - .env
    environment:
      DATABASE_URL: postgres://app:${POSTGRES_PASSWORD}@postgres:5432/app
      LISTEN_ADDR: 0.0.0.0:${SERVICE_PORT}
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "timeout 1 bash -c 'cat < /dev/null > /dev/tcp/127.0.0.1/${SERVICE_PORT}' || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 15s
    networks:
      - internal
      - edge

volumes:
  ${APP_NAME}_pg:

networks:
  internal:
    name: ${APP_NAME}_internal
  edge:
    external: true
    name: personal-cloud_edge
