# Generated by personal-cloud ship — do not edit by hand
name: ${APP_NAME}

services:
  app:
    image: ${IMAGE}:${IMAGE_TAG}
    container_name: ${SERVICE_CONTAINER}
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - ${DATA_HOST_PATH}:/data
    healthcheck:
      test: ["CMD-SHELL", "timeout 1 bash -c 'cat < /dev/null > /dev/tcp/127.0.0.1/${SERVICE_PORT}' || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 15s
    networks:
      - edge

networks:
  edge:
    external: true
    name: personal-cloud_edge
